# Protheus
PROTHEUS_URL=https://goncalvessalles202222.protheus.cloudtotvs.com.br:10553/webapp/
PROTHEUS_USER=seu_usuario
PROTHEUS_PASSWORD=sua_senha

# Redis / Celery
REDIS_URL=redis://localhost:6379/0

# API
API_HOST=0.0.0.0
API_PORT=8000

# Database (PostgreSQL)
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/gsfat

# Paths
LOG_DB_PATH=logs/poc_gsfat.db
SCREENSHOTS_DIR=screenshots
REPLAYS_DIR=replays
SPECS_DIR=specs

# Security (CHANGE IN PRODUCTION!)
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
API_KEY_HEADER=X-API-Key

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=100/minute

# CORS
CORS_ENABLED=true
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Observability
LOG_LEVEL=INFO
ENVIRONMENT=development
DEBUG=false

OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=gsfat-api
JAEGER_AGENT_HOST=localhost
JAEGER_AGENT_PORT=6831

# Sentry (Error Tracking - opcional)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# Circuit Breakers
CIRCUIT_BREAKER_PROTHEUS_FAIL_MAX=5
CIRCUIT_BREAKER_PROTHEUS_TIMEOUT=60
CIRCUIT_BREAKER_DB_FAIL_MAX=3
CIRCUIT_BREAKER_DB_TIMEOUT=30

# Dead Letter Queue
DLQ_ENABLED=true
DLQ_MAX_RETRIES=3
